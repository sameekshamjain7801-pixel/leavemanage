# ─── Flask Core ─────────────────────────────────
FLASK_ENV=development
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token_hex-32

# ─── Supabase Database ─────────────────────────
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# ─── SMTP Email (Gmail) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SENDER_NAME=LeaveFlow Administration

# ─── Admin Credentials (optional overrides) ───
HOD1_PASSWORD=admin123
HOD2_PASSWORD=admin123
PRINCIPAL_PASSWORD=admin123

# ─── Application Settings ─────────────────────
APP_URL=http://127.0.0.1:5000
DEFAULT_LEAVE_QUOTA=20
PORT=5000
